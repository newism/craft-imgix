{
    "name": "newism/craft-imgix",
    "description": "Imgix-powered asset transforms for Craft CMS",
    "license": "proprietary",
    "type": "craft-plugin",
    "keywords": [
        "craft",
        "cms",
        "craftcms",
        "craft-plugin",
        "imgix"
    ],
    "authors": [
        {
            "name": "Leevi Graham",
            "email": "leevi@newism.com.au"
        }
    ],
    "support": {
        "email": "support@newism.com.au",
        "source": "https://github.com/newism/craft-imgix",
        "docs": "https://plugins.newism.com.au/imgix-asset-transformer"
    },
    "require": {
        "php": ">=8.2",
        "craftcms/cms": "^5.6.0",
        "imgix/imgix-php": "^4.1"
    },
    "require-dev": {
        "craftcms/ecs": "dev-main",
        "craftcms/phpstan": "dev-main"
    },
    "autoload": {
        "psr-4": {
            "Newism\\Imgix\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        },
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    },
    "extra": {
        "handle": "newism-imgix",
        "class": "Newism\\Imgix\\Imgix",
        "name": "Imgix Asset Transformer",
        "developer": "Newism",
        "developerUrl": "https://newism.com.au",
        "documentationUrl": "https://plugins.newism.com.au/imgix-asset-transformer"
    },
    "scripts": {
        "check-cs": "ecs check --ansi",
        "fix-cs": "ecs check --ansi --fix",
        "phpstan": "phpstan --memory-limit=1G"
    }
}
